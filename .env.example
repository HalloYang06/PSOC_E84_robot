APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_DB=ai_collab
POSTGRES_USER=ai_collab
POSTGRES_PASSWORD=ai_collab
DATABASE_URL=sqlite:///./ai_collab.db

REDIS_URL=redis://redis:6379/0

INTERNAL_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_PROVIDER=legacy
NEXT_PUBLIC_SUPERTOKENS_APP_NAME=AI Collaboration Platform
NEXT_PUBLIC_SUPERTOKENS_API_DOMAIN=http://127.0.0.1:8000
NEXT_PUBLIC_SUPERTOKENS_API_BASE_PATH=/api/st-auth

AUTH_PROVIDER=legacy
SUPERTOKENS_CONNECTION_URI=
SUPERTOKENS_API_KEY=
SUPERTOKENS_APP_NAME=AI Collaboration Platform
SUPERTOKENS_API_DOMAIN=http://127.0.0.1:8000
SUPERTOKENS_WEBSITE_DOMAIN=http://lvh.me:3001
SUPERTOKENS_API_BASE_PATH=/api/st-auth
SUPERTOKENS_WEBSITE_BASE_PATH=/auth
SUPERTOKENS_EMAIL_VERIFICATION_MODE=REQUIRED
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SUPERTOKENS_COOKIE_SECURE=false
SUPERTOKENS_SMTP_HOST=
SUPERTOKENS_SMTP_PORT=587
SUPERTOKENS_SMTP_USERNAME=
SUPERTOKENS_SMTP_PASSWORD=
SUPERTOKENS_SMTP_FROM_NAME=AI Collaboration Platform
SUPERTOKENS_SMTP_FROM_EMAIL=
SUPERTOKENS_SMTP_SECURE=false

RUNNER_ID=runner-local
RUNNER_NAME=Local Runner
RUNNER_TOKEN=change-me
RUNNER_WORKDIR=./artifacts/runner-workspace
ALLOW_HARDWARE_ACCESS=false
