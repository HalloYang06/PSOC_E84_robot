<?xml version="1.0"?>
<robot name="rehab_arm">
  <link name="base_link"/>
  <link name="shoulder_link">
    <visual><origin xyz="0 0 0.15"/><geometry><box size="0.08 0.08 0.30"/></geometry></visual>
  </link>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="base_link"/><child link="shoulder_link"/>
    <origin xyz="0 0 0.1"/><axis xyz="0 1 0"/>
    <limit lower="-0.70" upper="1.40" effort="20" velocity="0.60"/>
  </joint>
  <link name="upper_arm_link">
    <visual><origin xyz="0.20 0 0"/><geometry><box size="0.40 0.06 0.06"/></geometry></visual>
  </link>
  <joint name="shoulder_abduction_joint" type="revolute">
    <parent link="shoulder_link"/><child link="upper_arm_link"/>
    <origin xyz="0 0 0.30"/><axis xyz="0 0 1"/>
    <limit lower="-0.45" upper="0.80" effort="20" velocity="0.40"/>
  </joint>
  <link name="upper_arm_rotation_link">
    <visual><origin xyz="0.10 0 0"/><geometry><cylinder radius="0.035" length="0.20"/></geometry></visual>
  </link>
  <joint name="upper_arm_rotation_joint" type="revolute">
    <parent link="upper_arm_link"/><child link="upper_arm_rotation_link"/>
    <origin xyz="0.40 0 0" rpy="0 1.5708 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.20" upper="1.20" effort="15" velocity="0.70"/>
  </joint>
  <link name="forearm_link">
    <visual><origin xyz="0.18 0 0"/><geometry><box size="0.36 0.05 0.05"/></geometry></visual>
  </link>
  <joint name="elbow_lift_joint" type="revolute">
    <parent link="upper_arm_rotation_link"/><child link="forearm_link"/>
    <origin xyz="0.20 0 0" rpy="0 -1.5708 0"/><axis xyz="0 1 0"/>
    <limit lower="0.00" upper="1.80" effort="20" velocity="0.70"/>
  </joint>
  <link name="hand_link">
    <visual><origin xyz="0.08 0 0"/><geometry><box size="0.16 0.08 0.04"/></geometry></visual>
  </link>
  <joint name="forearm_rotation_joint" type="revolute">
    <parent link="forearm_link"/><child link="hand_link"/>
    <origin xyz="0.36 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.20" upper="1.20" effort="12" velocity="0.70"/>
  </joint>
</robot>
