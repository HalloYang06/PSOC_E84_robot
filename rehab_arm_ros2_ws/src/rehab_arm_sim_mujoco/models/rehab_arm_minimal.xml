                        </body>
                    </body>
                </body>
            </body>
        </body>
    </body>
  </worldbody>
  <actuator>
    <position joint="shoulder_lift_joint" kp="35" kv="4" ctrlrange="-0.7 1.4"/>
    <position joint="elbow_lift_joint" kp="35" kv="4" ctrlrange="0.0 1.8"/>
    <position joint="shoulder_abduction_joint" kp="35" kv="4" ctrlrange="-0.45 0.8"/>
    <position joint="upper_arm_rotation_joint" kp="35" kv="4" ctrlrange="-1.2 1.2"/>
    <position joint="forearm_rotation_joint" kp="35" kv="4" ctrlrange="-1.2 1.2"/>
