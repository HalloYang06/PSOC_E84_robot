PUBLIC_APP_DOMAIN=coop.example.com
ACME_EMAIL=ops@example.com

POSTGRES_DB=ai_collab
POSTGRES_USER=ai_collab
POSTGRES_PASSWORD=change-me

SECRET_KEY=replace-with-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-long-random-token-key
RUNNER_REGISTRATION_TOKEN=replace-with-runner-registration-token

AUTH_PROVIDER=supertokens
SUPERTOKENS_CONNECTION_URI=https://try.supertokens.com
SUPERTOKENS_API_KEY=
SUPERTOKENS_APP_NAME=AI Collaboration Platform
SUPERTOKENS_EMAIL_VERIFICATION_MODE=REQUIRED

SUPERTOKENS_SMTP_HOST=smtp.example.com
SUPERTOKENS_SMTP_PORT=587
SUPERTOKENS_SMTP_USERNAME=smtp-user
SUPERTOKENS_SMTP_PASSWORD=smtp-password
SUPERTOKENS_SMTP_FROM_NAME=AI Collaboration Platform
SUPERTOKENS_SMTP_FROM_EMAIL=noreply@example.com
SUPERTOKENS_SMTP_SECURE=false
